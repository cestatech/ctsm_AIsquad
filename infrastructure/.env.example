# Copy to repo root as .env — used by docker compose and backend/.env
# Never commit .env to source control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=REPLACE_WITH_MIN_32_CHAR_RANDOM_STRING
APP_ALLOWED_ORIGINS=http://localhost:3000

# ─── Database (Docker Postgres — host port 5433) ─────────────────────────────
POSTGRES_PASSWORD=celerius_dev
DATABASE_URL=postgresql+asyncpg://celerius:celerius_dev@localhost:5433/celerius_dev

# ─── Redis (Docker) ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_WITH_MIN_32_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Auth rate limiting ──────────────────────────────────────────────────────
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_IP_MAX_FAILED_ATTEMPTS=5
AUTH_IP_WINDOW_MINUTES=15

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=filesystem
STORAGE_LOCAL_PATH=/tmp/celerius-storage

# ─── Email (Docker Mailhog) ───────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@celerius.dev
SMTP_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── AI (Anthropic Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Pinnacle 21 (purchase license later; placeholders until Phase 4 wire-up) ─
PINNACLE21_ENABLED=false
PINNACLE21_API_BASE_URL=https://api.pinnacle21.com
PINNACLE21_API_KEY=
PINNACLE21_PROJECT_ID=
PINNACLE21_RULE_SET_VERSION=CE 3.1
SDTM_IG_VERSION=3.3

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=TrialGenesis
NEXT_PUBLIC_APP_VERSION=0.1.0
