# Copy this file to .env and fill in actual values.
# Never commit .env to source control.

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=REPLACE_WITH_MIN_32_CHAR_RANDOM_STRING
APP_ALLOWED_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=celerius_dev
DATABASE_URL=postgresql+asyncpg://celerius:celerius_dev@localhost:5432/celerius_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=REPLACE_WITH_MIN_32_CHAR_RANDOM_STRING
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=filesystem
STORAGE_LOCAL_PATH=/tmp/celerius-storage

# For S3 (uncomment and fill for production):
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=celerius-artifacts

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@celerius.dev
SMTP_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=Celerius
NEXT_PUBLIC_APP_VERSION=0.1.0
