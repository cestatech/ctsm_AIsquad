# TrialGenesis / Celerius — Backend Environment Variables
# Copy this to backend/.env and fill in real values. Never commit backend/.env.

# Application
APP_ENV=development                          # development | staging | production
APP_SECRET_KEY=<generate-32-char-random-string>
APP_ALLOWED_ORIGINS=["http://localhost:3000"]   # JSON array; multi-origin: ["https://app.example.com","https://app2.example.com"]
APP_DEBUG=false

# Database (PostgreSQL via asyncpg)
DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>/<dbname>
DATABASE_ECHO=false

# Redis (used for rate-limiting and future job queue)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=<generate-32-char-random-string>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth rate limiting
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Storage
STORAGE_BACKEND=filesystem                   # filesystem | s3 | azure
STORAGE_LOCAL_PATH=/tmp/celerius-storage

# S3 (required when STORAGE_BACKEND=s3)
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Azure Blob (required when STORAGE_BACKEND=azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@trialgenesis.dev
SMTP_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
AI_MAX_CONCURRENT_JOBS=5
AI_JOB_TIMEOUT_SECONDS=300
