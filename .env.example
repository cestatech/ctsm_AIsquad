# TrialGenesis / Celerius — Docker development environment
# Copy to .env at repo root. Never commit .env.

# Application
APP_ENV=development
APP_SECRET_KEY=<generate-32-char-random-string>
APP_ALLOWED_ORIGINS=http://localhost:3000
APP_DEBUG=false

# Database (Docker Postgres on host port 5433)
POSTGRES_PASSWORD=celerius_dev
DATABASE_URL=postgresql+asyncpg://celerius:celerius_dev@localhost:5433/celerius_dev
DATABASE_ECHO=false

# Redis (Docker)
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=<generate-32-char-random-string>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Auth rate limiting
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Storage
STORAGE_BACKEND=filesystem
STORAGE_LOCAL_PATH=/tmp/celerius-storage

# Email (Docker Mailhog)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@trialgenesis.dev
SMTP_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=sk-ant-...
AI_MAX_CONCURRENT_JOBS=5
AI_JOB_TIMEOUT_SECONDS=300

# Pinnacle 21 — placeholders until license purchased (Phase 4 integration)
PINNACLE21_ENABLED=false
PINNACLE21_API_BASE_URL=https://api.pinnacle21.com
PINNACLE21_API_KEY=
PINNACLE21_PROJECT_ID=
PINNACLE21_RULE_SET_VERSION=CE 3.1
SDTM_IG_VERSION=3.3

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=TrialGenesis
NEXT_PUBLIC_APP_VERSION=0.1.0
